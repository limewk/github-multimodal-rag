# GitHub Integration
# Optional. Required only when you want to index GitHub open issues.
GITHUB_TOKEN=

# LLM configuration.
# Leave LLM_API_KEY and LLM_BASE_URL empty to use offline preview.
# For OpenAI-compatible gateways, fill all three fields below.
LLM_API_KEY=
LLM_BASE_URL=
LLM_CHAT_MODEL=gpt-4o
LLM_PROVIDER=
LLM_EXTRA_BODY=

# ModelScope example:
# LLM_API_KEY=your_modelscope_key
# LLM_BASE_URL=https://api-inference.modelscope.cn/v1
# LLM_CHAT_MODEL=deepseek-ai/DeepSeek-V3.2

# Embedding configuration.
# Default local development uses deterministic hash embeddings.
RAG_EMBEDDING_PROVIDER=hash
RAG_HASH_EMBEDDING_DIM=384

# To use OpenAI embeddings:
# OPENAI_API_KEY=your_openai_key
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# RAG_EMBEDDING_PROVIDER=openai

# Qdrant configuration.
# Local mode persists indexes under data/qdrant.
QDRANT_MODE=local
QDRANT_PATH=data/qdrant
QDRANT_COLLECTION=github_repo_multi_modal

# Remote Qdrant example:
# QDRANT_MODE=remote
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
# QDRANT_API_KEY=

# In-memory Qdrant example. Restarting the backend will lose indexes.
# QDRANT_LOCATION=:memory:

# Indexing limits.
RAG_REPO_CACHE_DIR=data/repos
RAG_MAX_TEXT_FILE_BYTES=1048576
RAG_INDEX_BATCH_SIZE=64
RAG_USE_GIT_LS_FILES=true
RAG_GIT_LS_FILES_TIMEOUT_SECONDS=60

# Hybrid retrieval.
RAG_RETRIEVAL_K=16
RAG_REPO_CONTEXT_DOC_LIMIT=8
RAG_MAX_CONTEXT_CHARS=24000
RAG_HYBRID_VECTOR_CANDIDATES=48
RAG_HYBRID_KEYWORD_CANDIDATES=800
RAG_HYBRID_NEIGHBOR_WINDOW=1

# OCR for uploaded images and repository image assets.
# Requires system Tesseract. Chinese OCR needs the chi_sim language package.
OCR_ENABLED=true
OCR_LANGS=eng+chi_sim
OCR_TESSERACT_CMD="D:\OCR/tesseract.exe"
OCR_TIMEOUT_SECONDS=20
OCR_MAX_TEXT_CHARS=8000

# App Settings
LOG_LEVEL=INFO

# Github Integration
GITHUB_TOKEN=your_github_personal_access_token_here

## 以下为 LLM 大模型配置
# 如果使用 OpenAI 官方接口
# OPENAI_API_KEY=your_openai_api_key_here

# 推荐使用通用配置，兼容各种支持 OpenAI 接口格式的模型（如 DeepSeek, Qwen, 通义千问, 智谱, 或本地的 Ollama/vLLM）
LLM_API_KEY=your_llm_api_key_here
# 例如 DeepSeek: https://api.deepseek.com/v1, 本地 Ollama: http://localhost:11434/v1
LLM_BASE_URL=
LLM_CHAT_MODEL=gpt-4o
# Optional: provider name required by some OpenAI-compatible gateways.
LLM_PROVIDER=
# Optional: extra JSON body sent with each request.
# Example: {"provider":"minimax"}
LLM_EXTRA_BODY=

# Vector DB configs (example for Qdrant)
QDRANT_MODE=local
QDRANT_PATH=data/qdrant
# Set QDRANT_MODE=remote to use a Docker/Cloud Qdrant endpoint.
QDRANT_HOST=localhost
QDRANT_PORT=6333

# App Settings
LOG_LEVEL=INFO

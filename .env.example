# GitHub Integration
GITHUB_TOKEN=your_github_personal_access_token_here

# LLM configuration. Leave LLM_BASE_URL empty for the default OpenAI endpoint.
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=
LLM_CHAT_MODEL=gpt-4o
LLM_PROVIDER=
LLM_EXTRA_BODY=


# Embedding configuration. If OPENAI_API_KEY is empty, local hash embeddings are used.
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_PROVIDER=openai
RAG_HASH_EMBEDDING_DIM=384


# Qdrant configuration.
QDRANT_MODE=local
QDRANT_PATH=data/qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=github_repo_multi_modal

# Indexing limits.
RAG_REPO_CACHE_DIR=data/repos
RAG_MAX_TEXT_FILE_BYTES=1048576
RAG_INDEX_BATCH_SIZE=64
RAG_USE_GIT_LS_FILES=true
RAG_GIT_LS_FILES_TIMEOUT_SECONDS=60

# Phase 2 hybrid retrieval.
RAG_RETRIEVAL_K=16
RAG_REPO_CONTEXT_DOC_LIMIT=8
RAG_MAX_CONTEXT_CHARS=24000
RAG_HYBRID_VECTOR_CANDIDATES=48
RAG_HYBRID_KEYWORD_CANDIDATES=800
RAG_HYBRID_NEIGHBOR_WINDOW=1

# App Settings
LOG_LEVEL=INFO














